{
  "name": "bible-canvas",
  "version": "1.0.0",
  "description": "Bible Canvas",
  "type": "module",
  "main": "dist/electron-app/main.js",
  "scripts": {
    "dev": "vite",
    "start": "npm run build && electron .",
    "build:react": "tsx ./build.mts",
    "build:electron": "tsc --project tsconfig.preload.json && tsc --project tsconfig.electron.json",
    "build": "npm run build:react && npm run build:electron",
    "package": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.8.0",
    "tldraw": "^4.4.0"
  },
  "build": {
    "appId": "com.marcosduarte.biblecanvas",
    "productName": "Bible Canvas",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "book.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^24.9.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^39.0.0",
    "electron-builder": "^26.8.1",
    "fast-glob": "^3.3.3",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
